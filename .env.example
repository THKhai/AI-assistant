DEEPSEEK_API_KEY=your_deepseek_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id_here

# Vector store backend: "chroma" (Windows default) or "qdrant" (Linux/Docker)
VECTOR_BACKEND=chroma

# Only needed when VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333

# Web UI auth — generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY_HOURS=24

# "dev" = HTTP localhost (secure cookie flag off)
# "prod" = HTTPS via Cloudflare Tunnel (secure cookie + HSTS headers on)
# docker-compose.yml overrides this to "prod" automatically
ENVIRONMENT=dev

# Cloudflare Tunnel token — get from Zero Trust dashboard → Networks → Tunnels
# Leave blank when running locally without Docker
CLOUDFLARE_TUNNEL_TOKEN=

# Optional local HTTPS — run scripts/gen_cert.py to generate, then set these:
HTTPS_CERT_FILE=
HTTPS_KEY_FILE=

# Login rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Refresh tokens (long-lived, renewed silently by the frontend on 401)
REFRESH_TOKEN_EXPIRY_DAYS=30

# TOTP issuer name shown in authenticator apps
TOTP_ISSUER=AI Assistant
